      <aliases enabled='yes' />
      <column caption='Is Fraud' datatype='boolean' name='[Calculation_1969092220264448]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [fraud_label] = &quot;Normal&quot; then FALSE ELSE TRUE END' />
      </column>
      <column caption='Fraud Transactions' datatype='integer' name='[Calculation_1969092225499138]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(If [fraud_label]= &quot;Fraud&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Fraud Rate' datatype='real' name='[Calculation_1969092226306051]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [fraud_label] = &quot;Fraud&quot; THEN 1 ELSE 0 END) / (COUNTD([customer_id]))' />
      </column>
      <column caption='Transaction Hour' datatype='integer' name='[Calculation_1969092226871300]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART (&quot;hour&quot;, [transaction_time])' />
      </column>
      <column caption='High Risk Flag' datatype='string' name='[Calculation_1969092227227653]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [distance_from_home] &gt; 50&#10;OR [failed_transaction_count] &gt; 0&#10;OR [unusual_time_transaction] = &quot;Yes&quot;&#10;THEN &quot;High Risk&quot;&#10;ELSE &quot;Low Risk&quot;&#10;END' />
      </column>
      <column caption='Risk Score' datatype='integer' name='[Calculation_1969092227969030]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [previous_fraud_count]&gt; 0 THEN 3 ELSE 0 END&#10;+&#10;IF [is_international_transaction] = &quot;Yes&quot; THEN 2 ELSE 0 END&#10;+&#10;IF [is_new_merchant] = &quot;Yes&quot; THEN 1 ELSE 0 END&#10;+&#10;IF [failed_transaction_count] &gt; 0 THEN 1 ELSE 0 END&#10;+&#10;IF [distance_from_home]&gt; 50 THEN 2 ELSE 0 END' />
      </column>
      <column caption='Total Transactions' datatype='integer' name='[Calculation_1969092243726343]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([customer_id])' />
      </column>
      <column caption='Average Trans Ammount' datatype='real' name='[Calculation_1969092244160520]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([transaction_amount_in_million])' />
      </column>
      <column caption='Av Distance from Home' datatype='real' name='[Calculation_1969092244328457]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([distance_from_home])' />
      </column>
      <column caption='Number of Customers' datatype='integer' name='[Calculation_1969092244447242]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id])' />
      </column>
      <column caption='day of week' datatype='string' name='[Calculation_2542487735803904]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, transaction_date)' />
      </column>
      <column aggregation='None' datatype='integer' name='[Transaction Amount In Million (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='0' formula='[transaction_amount_in_million]' peg='0' size='1.328' />
      </column>
      <column caption='clean_fraud_df.csv' datatype='table' name='[__tableau_internal_object_id__].[clean_fraud_df.csv_75DB7973F70143D5A98493EFCFDD727F]' role='measure' type='quantitative' />
      <column caption='Account Balance In Million' datatype='real' name='[account_balance_in_million]' role='measure' type='quantitative' />
      <column caption='Avg Transaction Amount In Million' datatype='real' name='[avg_transaction_amount_in_million]' role='measure' type='quantitative' />
      <column caption='Card Type' datatype='string' name='[card_type]' role='dimension' type='nominal' />
